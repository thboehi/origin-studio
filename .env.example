# Contact Form Security
FORM_SECRET=change-this-to-a-random-string-in-production

# Email Configuration (Infomaniak SMTP)
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_USER=your-email@your-domain.ch
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM=your-email@your-domain.ch
SMTP_FROM_NAME="Your Name from Your Company"
SMTP_TO=destination-email@your-domain.ch

# Discord Webhook for review notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Site URL (for emails and Discord embeds)
NEXT_PUBLIC_SITE_URL=https://your-domain.ch

# Test webhook